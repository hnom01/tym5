<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #6A040F;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="cz.vse.avatask.RegistraciaController">
   <padding>
      <Insets bottom="20.0" left="24.0" right="24.0" top="20.0" />
   </padding>
   <children>
      <Label text="Registrácia" textFill="WHITE" />
      <TextField fx:id="usernameField" promptText="Prihlasovacie meno" />
      <TextField fx:id="emailField" promptText="Email" />
      <PasswordField fx:id="passwordField" promptText="Heslo" />
      <PasswordField fx:id="confirmPasswordField" promptText="Potvrdiť heslo" />
      <Button mnemonicParsing="false" onAction="#registrujSa" text="Vytvoriť účet" />
   </children>
</VBox>
