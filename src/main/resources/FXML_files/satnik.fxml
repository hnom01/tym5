<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="cz.vse.avatask.SatnikController" styleClass="hlavne-pozadie" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="430.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="horna-lista" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
            </padding>
            <children>
                <Label fx:id="hornyLevelLabel" style="-fx-font-weight: bold; -fx-font-style: italic;" text="Level X" textFill="WHITE" />
                <Label fx:id="hornyXpLabel" text="XP: xxx" textFill="WHITE">
                    <font>
                        <Font name="System Bold Italic" size="12.0" />
                    </font>
                </Label>
                <Label fx:id="hornaMenaLabel" text="Mince: 0" textFill="#ffcc00">
                    <font>
                        <Font name="System Bold" size="12.0" />
                    </font>
                </Label>
                <Region prefWidth="1.0" minHeight="22.0" style="-fx-background-color: rgba(255,255,255,0.35);">
                    <HBox.margin><Insets left="8.0" right="8.0" /></HBox.margin>
                </Region>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#otvorUlohy" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" text="Moje úlohy" textFill="WHITE" />
                <Button mnemonicParsing="false" onAction="#otvorStatistiky" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" text="Štatistiky" textFill="WHITE" />
                <Button mnemonicParsing="false" onAction="#otvorProfil" style="-fx-background-color: transparent; -fx-font-weight: bold; -fx-cursor: hand;" text="Môj profil" textFill="WHITE" />
                <ImageView fitHeight="38.0" fitWidth="102.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@avatask.png" />
                    </image>
                </ImageView>
            </children>
        </HBox>
    </top>
    <left>
        <VBox alignment="CENTER" prefWidth="240.0" spacing="10.0" styleClass="horna-lista" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
            </padding>
            <children>
                <Label fx:id="menoLabel" text="Pouzivatel" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Label>
                <StackPane fx:id="avatarStackPane" prefHeight="320.0" prefWidth="220.0">
                    <children>
                        <ImageView fx:id="avatarBaseImageView" fitHeight="310.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@muz_basic.png" />
                            </image>
                        </ImageView>
                        <ImageView fx:id="avatarNahrdelnikImageView" fitHeight="310.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" />
                        <ImageView fx:id="avatarSiltovkaImageView" fitHeight="310.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" />
                        <ImageView fx:id="avatarKlobukImageView" fitHeight="310.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" />
                        <ImageView fx:id="avatarOkuliareImageView" fitHeight="310.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true" />
                    </children>
                </StackPane>
                <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#obnovAvatar" style="-fx-background-color: white; -fx-font-weight: bold; -fx-text-fill: black;" text="Obnovit avatar" />
                <Label fx:id="statusLabel" textFill="WHITE" wrapText="true" />
            </children>
        </VBox>
    </left>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER" style="-fx-background-color: transparent;">
            <tabs>
                <Tab text="Obchod">
                    <content>
                        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <TilePane fx:id="obchodTilePane" hgap="14.0" prefColumns="3" vgap="14.0" style="-fx-background-color: transparent;">
                                    <padding>
                                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                                    </padding>
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
                <Tab text="Môj šatník">
                    <content>
                        <ScrollPane fitToHeight="true" fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                            <content>
                                <TilePane fx:id="satnikTilePane" hgap="14.0" prefColumns="3" vgap="14.0" style="-fx-background-color: transparent;">
                                    <padding>
                                        <Insets bottom="12.0" left="12.0" right="12.0" top="12.0" />
                                    </padding>
                                </TilePane>
                            </content>
                        </ScrollPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>